# ============================================
# TempleAI Voice Assistant — Environment Variables
# ============================================
# Copy this file to:
#   backend/.env       (for FastAPI backend)
#   frontend/.env.local (for Next.js frontend)
# ============================================

# --- OpenAI (Required for AI Chat + Speech-to-Text) ---
OPENAI_API_KEY=your_openai_api_key_here

# --- ElevenLabs (Required for Text-to-Speech) ---
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=your_voice_id_here

# --- MongoDB Atlas (Required for Database) ---
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/templeai?retryWrites=true&w=majority

# --- Server Configuration ---
PORT=8000
FRONTEND_URL=http://localhost:3000

# --- Temple Configuration ---
TEMPLE_NAME=Sri Raghavendra Swamy Temple

# --- Optional: Google Translate ---
GOOGLE_TRANSLATE_API_KEY=

# --- Optional: Azure Speech (alternative STT) ---
AZURE_SPEECH_KEY=
AZURE_REGION=
